// grammar.lark
// Gramática del Conversor de Divisas para Lark (parser LALR)

start: expresion

expresion: NUMERO MONEDA A MONEDA FIN

NUMERO: /\d+(\.\d+)?/

MONEDA: "DólarEstadounidense"
      | "EuroUnión"
      | "LempiraHondureño"
      | "PesoMexicano"
      | "LibraEsterlina"
      | "YenJaponés"
      | "ColonCostarricense"

A: "a"
FIN: "$"

%ignore " "
%ignore "\t"
